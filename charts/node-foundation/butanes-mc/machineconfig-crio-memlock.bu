variant: openshift
version: 4.11.0
metadata:
  name: 99-gpu-hpc-crio-memlock
  labels:
    machineconfiguration.openshift.io/role: gpu-hpc
storage:
  files:
    - path: /etc/crio/crio.conf.d/99-rdma-memlock.conf
      mode: 0644
      overwrite: true
      contents:
        inline: |
          [crio.runtime]
          default_ulimits = [ "memlock=-1:-1" ]
